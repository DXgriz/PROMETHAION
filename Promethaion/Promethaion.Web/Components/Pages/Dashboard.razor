@page "/dashboard"
@inject IPromethaionApiClient Api
@using Promethaion.Web.Models
@using Promethaion.Web.Services
@using static Promethaion.Web.Models.ApiModels

<PageTitle>Dashboard — Promethaion</PageTitle>

<div class="top-bar">
    <div class="page-title">DASH<span>BOARD</span></div>
    <div style="display:flex;gap:8px;align-items:center;">
        @if (_status?.ModelsLoaded == true)
        { <span class="badge badge-green">● Models Active</span> }
        else { <span class="badge badge-dim">○ Models Inactive</span> }
        @if (_status?.ShouldRetrain == true)
        { <span class="badge badge-red">⚠ Retrain Needed</span> }
    </div>
</div>

<div class="page-body">
    @if (_loading)
    {
        <div class="loading-overlay"><div class="spinner"></div><span>Loading…</span></div>
    }
    else
    {
        <div class="stat-grid">
            <div class="stat-card" style="--accent:var(--gold)">
                <div class="stat-label">Pattern Events</div>
                <div class="stat-value">@(_status?.TotalDraws.ToString("N0") ?? "0")</div>
                <div class="stat-sub">Historical records</div>
            </div>
            <div class="stat-card" style="--accent:var(--blue)">
                <div class="stat-label">Forecasts</div>
                <div class="stat-value">@(_status?.TotalPredictions ?? 0)</div>
                <div class="stat-sub">@(_status?.EvaluatedPredictions ?? 0) evaluated</div>
            </div>
            <div class="stat-card" style="--accent:var(--success-light)">
                <div class="stat-label">Rolling Accuracy</div>
                <div class="stat-value text-success">@(_status?.RollingAccuracy.ToString("F2") ?? "0.00")</div>
                <div class="stat-sub">avg matches / forecast</div>
            </div>
            <div class="stat-card" style="--accent:var(--text-dim)">
                <div class="stat-label">Model Version</div>
                <div class="stat-value" style="font-size:13px;padding-top:8px;">@(_status?.LatestModelVersion ?? "untrained")</div>
                <div class="stat-sub">
                    @if (_status?.LastTrainedAt.HasValue == true)
                    { @_status.LastTrainedAt.Value.ToString("dd MMM yyyy") }
                    else { <span>Never trained</span> }
                </div>
            </div>
        </div>

        <div class="grid-2 section-gap">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Latest Forecast</span>
                    <a href="/forecasts" class="btn btn-outline btn-sm">View All →</a>
                </div>
                @if (_latestForecast is null)
                {
                    <div class="empty-state">
                        <div class="empty-icon">◎</div>
                        <p>No forecasts yet.</p>
                        <a href="/forecasts" class="btn btn-gold btn-sm" style="margin-top:12px;">Generate First Forecast</a>
                    </div>
                }
                else
                {
                    <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;">
                        <span class="badge badge-dim">Draw #@_latestForecast.TargetDrawNumber</span>
                        <span class="badge badge-gold">@(_latestForecast.ConfidenceScore.ToString("P1")) confidence</span>
                        @if (_latestForecast.MatchCount.HasValue)
                        { <span class="badge badge-@(_latestForecast.MatchCount >= 3 ? "green" : "dim")">@_latestForecast.MatchCount matched</span> }
                        else { <span class="badge badge-dim">Awaiting result</span> }
                    </div>
                    <div class="ball-row" style="margin-bottom:12px;">
                        @foreach (var b in new[]{ _latestForecast.Ball1,_latestForecast.Ball2,_latestForecast.Ball3,
                                                  _latestForecast.Ball4,_latestForecast.Ball5,_latestForecast.Ball6 })
                        { <div class="ball main">@b</div> }
                        @if (_latestForecast.BonusBall.HasValue)
                        {
                            <span class="text-dim" style="font-size:11px;align-self:center;">+</span>
                            <div class="ball bonus">@_latestForecast.BonusBall</div>
                        }
                    </div>
                    <div class="text-dim" style="font-size:11px;">Generated @_latestForecast.GeneratedAt.ToString("dd MMM yyyy · HH:mm")</div>
                }
            </div>

            <div class="card">
                <div class="card-header"><span class="card-title">Intelligence Status</span></div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;">
                    <div class="d-aw-item">
                        <div class="d-aw-label">Self-Awareness</div>
                        @if (_accuracy?.ShouldRetrain == true)
                        { <div class="d-aw-val text-danger">⚠ Retrain Signal</div> }
                        else { <div class="d-aw-val text-success">✓ Stable</div> }
                    </div>
                    <div class="d-aw-item">
                        <div class="d-aw-label">Models</div>
                        <div class="d-aw-val @(_status?.ModelsLoaded == true ? "text-success" : "text-danger")">
                            @(_status?.ModelsLoaded == true ? "✓ Loaded" : "✗ Not Loaded")
                        </div>
                    </div>
                    <div class="d-aw-item">
                        <div class="d-aw-label">Evaluated</div>
                        <div class="d-aw-val">@(_status?.EvaluatedPredictions ?? 0)</div>
                    </div>
                    <div class="d-aw-item">
                        <div class="d-aw-label">Window</div>
                        <div class="d-aw-val">@(_accuracy?.Window ?? 20) draws</div>
                    </div>
                </div>
                <div class="d-aw-label" style="margin-bottom:6px;">Accuracy Score</div>
                <div class="progress-track">
                    <div class="progress-fill" style="width:@(Math.Min((_accuracy?.RollingAccuracy ?? 0)/6.0*100,100).ToString("F0"))%"></div>
                </div>
                <div style="display:flex;justify-content:space-between;margin-top:6px;">
                    <span class="text-dim" style="font-size:11px;">0.00</span>
                    <span class="text-gold" style="font-size:12px;font-weight:600;">@(_accuracy?.RollingAccuracy.ToString("F2") ?? "0.00") / 6.00</span>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title">Recent Pattern Events</span>
                <a href="/events" class="btn btn-outline btn-sm">Manage →</a>
            </div>
            @if (_recentEvents.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">≡</div>
                    <p>No events yet. <a href="/events" class="text-gold">Import data</a> to begin.</p>
                </div>
            }
            else
            {
                <table class="data-table">
                    <thead><tr><th>Draw #</th><th>Date</th><th>Numbers</th><th>Bonus</th><th>Sum</th><th>Odd/Even</th></tr></thead>
                    <tbody>
                        @foreach (var e in _recentEvents)
                        {
                            <tr>
                                <td class="text-gold text-mono">#@e.DrawNumber</td>
                                <td class="text-muted">@e.DrawDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="ball-row">
                                        @foreach (var b in new[]{e.Ball1,e.Ball2,e.Ball3,e.Ball4,e.Ball5,e.Ball6})
                                        { <div class="ball main" style="width:28px;height:28px;font-size:10px;">@b</div> }
                                    </div>
                                </td>
                                <td>@if(e.BonusBall.HasValue){<div class="ball bonus" style="width:28px;height:28px;font-size:10px;">@e.BonusBall</div>}</td>
                                <td class="text-muted">@e.Sum</td>
                                <td><span class="text-gold">@e.OddCount</span><span class="text-dim"> / </span><span class="text-blue">@e.EvenCount</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

<style>
    .d-aw-item { background:var(--bg-panel);border-radius:var(--radius);padding:12px;border:1px solid var(--border); }
    .d-aw-label { font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);margin-bottom:5px; }
    .d-aw-val { font-size:14px;font-weight:600;color:var(--text-primary); }
</style>

@code {
    private SystemStatusDto?      _status;
    private ForecastDto?          _latestForecast;
    private AccuracyDto?          _accuracy;
    private List<PatternEventDto> _recentEvents = [];
    private bool                  _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Task.WhenAll(
                Api.GetSystemStatusAsync().ContinueWith(t  => _status         = t.Result),
                Api.GetLatestForecastAsync().ContinueWith(t => _latestForecast = t.Result),
                Api.GetAccuracyAsync().ContinueWith(t       => _accuracy       = t.Result),
                Api.GetRecentEventsAsync(8).ContinueWith(t  => _recentEvents   = t.Result)
            );
        }
        finally { _loading = false; }
    }
}